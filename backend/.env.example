# WhatsApp OTP API (otp.kztusdt.kz) — login codes via WhatsApp.
# Token: https://otp.kztusdt.kz/admin → API tokens
OTP_API_TOKEN=
OTP_API_BASE_URL=https://otp.kztusdt.kz/api
OTP_API_PURPOSE=login
OTP_CODE_LENGTH=6
OTP_CODE_TTL=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN=60

# NCANode (ЭЦП НУЦ РК) — docker compose up ncanode
NCANODE_BASE_URL=http://127.0.0.1:14579
NCANODE_TIMEOUT=30
NCANODE_VERIFY_OCSP=true
NCANODE_VERIFY_CRL=true
LEGAL_ENTITY_EDS_REQUIRED=true
LEGAL_ENTITY_EDS_CHALLENGE_TTL=600
NCANODE_SKIP_VERIFICATION=false

# --- Web Push (PWA notifications) ---
# Generate a key pair with: php artisan webpush:vapid
VAPID_SUBJECT=https://kztusdt.kz
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Aitu Passport (OAuth 2.0 / OpenID) — единая аутентификация.
# client_id / client_secret выдаются в клиентской консоли Aitu Passport
# после создания сервиса Партнёра. Эндпоинты по умолчанию — для прод-хоста;
# на тестовой площадке задайте AITU_BASE_URL и при необходимости пути.
AITU_CLIENT_ID=
AITU_CLIENT_SECRET=
AITU_BASE_URL=https://passport.aitu.io
AITU_AUTHORIZE_PATH=/oauth2/auth
AITU_TOKEN_PATH=/api/v1/oauth/token
AITU_LOGOUT_PATH=/sessions/logout
# Для KYC через Aitu (KYC_PROVIDER=aitu) добавьте scope верификации из раздела
# «Доступы по подписке» консоли, например: "openid phone CONFIDENCE_LEVEL".
AITU_SCOPE="openid phone"
AITU_LOCALE=ru
AITU_HTTP_TIMEOUT=15
AITU_LOGOUT_WEBHOOK_SECRET=
# Подпись ИИН (oauth-параметр iin_signature). Публичный ключ → в консоль Aitu,
# приватный → сюда. Сгенерировать: php artisan aitu:generate-iin-keys
# Инлайн-PEM (переводы строк как \n) ИЛИ путь к файлу — что-то одно.
AITU_IIN_PRIVATE_KEY=
AITU_IIN_PRIVATE_KEY_PATH=
# «Валидация на стороне клиента» — Basic-авторизация запроса Aitu Passport.
# validator_id = логин, secret = пароль (те же значения, что в консоли Aitu).
# Пусто = проверка авторизации отключена.
AITU_VALIDATOR_ID=
AITU_CLIENT_VALIDATION_SECRET=
# KYC через Aitu Passport. Пусто = значения по умолчанию из config/aitu.php.
# claims — ключи id_token со статусом верификации; passed/failed — их значения.
AITU_VERIFY_CLAIMS=
AITU_VERIFY_PASSED_VALUES=
AITU_VERIFY_FAILED_VALUES=

# --- KYC provider: manual (default) | sumsub | aitu ---
KYC_PROVIDER=manual
# Ручная подача документов (можно включить параллельно с Aitu/Sumsub)
KYC_MANUAL_ENABLED=true
# Показывать Sumsub-заявки в /admin/kyc (код Sumsub остаётся в проекте)
KYC_ADMIN_SUMSUB_ENABLED=false

SESSION_DRIVER=database
SESSION_COOKIE=kztusdt_session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

